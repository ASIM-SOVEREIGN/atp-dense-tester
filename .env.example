# ATP Dense Tester Configuration
# Copy this file to .env and fill in your values

# ============================================================
# SOVEREIGN ENDPOINTS (where your ATP-enabled AIs live)
# ============================================================
# Format: JSON object with sovereign_id: endpoint_url
SOVEREIGN_ENDPOINTS='{
    "vexr-ultra": "https://vexr-ultra.onrender.com",
    "asim-pilot": "https://sovereign-forge.netlify.app",
    "iai-genesis": "https://sovereign-forge.netlify.app"
}'

# ============================================================
# ATP CRYPTO (Ed25519)
# ============================================================
# Your bridge's public key for verifying receipts
ATP_BRIDGE_PUBLIC_KEY="ed25519:YOUR_PUBLIC_KEY_HERE"

# Optional: private key for signing test intents (if tester signs its own)
ATP_TESTER_PRIVATE_KEY="ed25519:YOUR_PRIVATE_KEY_HERE"

# ============================================================
# DATABASE (Neon PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://username:password@ep-xxxx.neon.tech/dbname"

# ============================================================
# OPTIONAL: Groq for dynamic intent generation
# ============================================================
GROQ_API_KEY="your_groq_api_key_here"

# ============================================================
# TEST CONFIGURATION
# ============================================================
DEFAULT_PARALLEL_TESTS=3
DEFAULT_TIMEOUT_SECONDS=30
DENSE_TEST_BATCH_SIZE=50
WS_PROGRESS_ENABLED=true
